{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@davecodes/pi-subagents/src/extension/index.ts": ["./src/subagents-fork.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
